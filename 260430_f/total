<!-- 입력 링크들이 어느 도엽에 분포하는지 식별 -->
<select id="selectMapIdsByLinkIds" resultType="Integer">
    SELECT DISTINCT LINK_MAP_ID
    FROM   RTM_LINK
    WHERE  LINK_ID IN
    <foreach item="id" collection="linkIds" open="(" close=")" separator=",">
        #{id}
    </foreach>
</select>

<!-- 식별된 도엽들의 RTM_LINK 전체 로딩 (BFS 그래프 구성용) -->
<select id="selectLinksByMapIds" resultType="LinkVo">
    SELECT 
        LINK_ID     AS linkId,
        LINK_MAP_ID AS linkMapId,
        ST_ND_ID    AS stNdId,
        ED_ND_ID    AS edNdId
    FROM   RTM_LINK
    WHERE  LINK_MAP_ID IN
    <foreach item="id" collection="mapIds" open="(" close=")" separator=",">
        #{id}
    </foreach>
</select>

<!--
    해당 도엽들의 경계 노드(NODE_KIND=7)와 인접 도엽 짝 노드를 한 번에 조회.
    RTM_NODE에 ADJ_NODE_ID, ADJ_NODE_MAP_ID 컬럼이 있다면 그대로 사용.
    없다면 NODE_XY_GRS 좌표로 self-join 필요 (아래 [Plan B] 참고)
-->
<select id="selectNodesByMapIds" resultType="NodeVo">
    SELECT 
        NODE_ID        AS nodeId,
        NODE_MAP_ID    AS nodeMapId,
        NODE_KIND      AS nodeKind,
        ADJ_NODE_ID    AS adjNodeId,
        ADJ_NODE_MAP_ID AS adjNodeMapId
    FROM   RTM_NODE
    WHERE  NODE_MAP_ID IN
    <foreach item="id" collection="mapIds" open="(" close=")" separator=",">
        #{id}
    </foreach>
</select>


/**
 * 시작 노드에서 그래프 탐색하여 입력 링크 ID들의 도엽 ID를 정확히 찾는다.
 * 
 * 처리 방식:
 *  1. 입력 링크들이 분포한 도엽들을 식별
 *  2. 해당 도엽들의 모든 링크/노드를 메모리로 일괄 로딩
 *  3. 메모리 BFS로 시작점에서 도달 가능한 영역 탐색
 *  4. 마주친 링크들 중 입력에 포함된 것만 결과로 반환
 *
 * 성능:
 *  - DB 호출 3회 (도엽 식별 + 링크 로딩 + 노드 로딩)
 *  - BFS는 모두 메모리에서 실행 → 14,000개 처리 시 1초 이내 예상
 */
private Map<Integer, Integer> getMapIdsByNode(
        Integer startNodeId,
        Integer startNodeMapId,
        Collection<Integer> linkIds) throws IOException {

    if (linkIds == null || linkIds.isEmpty()) {
        return Collections.emptyMap();
    }

    Set<Integer> targetLinkIds = new HashSet<>(linkIds);

    // ─────────────────────────────────────────────────────────────
    // (1) 후보 도엽 식별
    //     입력 링크들이 분포된 LINK_MAP_ID 목록 조회
    // ─────────────────────────────────────────────────────────────
    List<Integer> candidateMapIds = dao.selectMapIdsByLinkIds(Map.of(
        "linkIds", linkIds
    ));

    // 시작 노드가 있는 도엽도 포함 (탐색 시작점 보장)
    if (!candidateMapIds.contains(startNodeMapId)) {
        candidateMapIds = new ArrayList<>(candidateMapIds);
        candidateMapIds.add(startNodeMapId);
    }

    // ─────────────────────────────────────────────────────────────
    // (2) 해당 도엽들의 그래프 데이터를 메모리로 일괄 로딩
    // ─────────────────────────────────────────────────────────────
    List<LinkVo> allLinks = dao.selectLinksByMapIds(Map.of(
        "mapIds", candidateMapIds
    ));
    List<NodeVo> allNodes = dao.selectNodesByMapIds(Map.of(
        "mapIds", candidateMapIds
    ));

    // ─────────────────────────────────────────────────────────────
    // (3) 메모리 인덱스 구성: 빠른 룩업을 위해 Map으로 재구조화
    // ─────────────────────────────────────────────────────────────

    // 노드 위치(nodeId+mapId) → 노드 정보
    Map<String, NodeVo> nodeIndex = new HashMap<>(allNodes.size() * 2);
    for (NodeVo n : allNodes) {
        nodeIndex.put(nodeKey(n.getNodeId(), n.getNodeMapId()), n);
    }

    // 노드 위치 → 그 노드에 연결된 링크들 (인접 리스트)
    Map<String, List<LinkVo>> adjacency = new HashMap<>(allLinks.size());
    for (LinkVo l : allLinks) {
        // 시작 노드 쪽
        adjacency
            .computeIfAbsent(nodeKey(l.getStNdId(), l.getLinkMapId()), k -> new ArrayList<>())
            .add(l);
        // 끝 노드 쪽
        adjacency
            .computeIfAbsent(nodeKey(l.getEdNdId(), l.getLinkMapId()), k -> new ArrayList<>())
            .add(l);
    }

    // ─────────────────────────────────────────────────────────────
    // (4) BFS 실행: 시작 노드에서 그래프 탐색
    // ─────────────────────────────────────────────────────────────
    Map<Integer, Integer> linkIdToMapId = new HashMap<>();
    Set<String> visitedNodes = new HashSet<>();
    Deque<NodePos> queue = new ArrayDeque<>();

    queue.offer(new NodePos(startNodeId, startNodeMapId));
    visitedNodes.add(nodeKey(startNodeId, startNodeMapId));

    while (!queue.isEmpty()) {
        NodePos cur = queue.poll();

        // 현재 노드에 연결된 링크 목록 (메모리 룩업)
        List<LinkVo> connected = adjacency.getOrDefault(
            nodeKey(cur.nodeId, cur.nodeMapId), Collections.emptyList());

        for (LinkVo link : connected) {
            Integer linkId    = link.getLinkId();
            Integer linkMapId = link.getLinkMapId();

            // 입력 링크면 결과에 기록 (먼저 도달한 도엽 우선)
            if (targetLinkIds.contains(linkId)) {
                linkIdToMapId.putIfAbsent(linkId, linkMapId);
            }

            // 반대편 노드 결정
            Integer oppositeNodeId = link.getStNdId().equals(cur.nodeId)
                ? link.getEdNdId()
                : link.getStNdId();

            // 반대편 노드 정보로 도엽 경계 여부 확인
            NodeVo oppNode = nodeIndex.get(nodeKey(oppositeNodeId, linkMapId));

            Integer nextNodeId;
            Integer nextNodeMapId;

            if (oppNode != null && oppNode.getNodeKind() != null
                    && oppNode.getNodeKind() == 7
                    && oppNode.getAdjNodeId() != null) {
                // 도엽 경계 노드 → 인접 도엽의 짝 노드로 점프
                nextNodeId    = oppNode.getAdjNodeId();
                nextNodeMapId = oppNode.getAdjNodeMapId();
            } else {
                // 일반 노드 → 그대로 진행
                nextNodeId    = oppositeNodeId;
                nextNodeMapId = linkMapId;
            }

            // 미방문이면 큐에 추가
            String nextKey = nodeKey(nextNodeId, nextNodeMapId);
            if (visitedNodes.add(nextKey)) {
                queue.offer(new NodePos(nextNodeId, nextNodeMapId));
            }

            // 모든 입력 링크를 다 찾았다면 조기 종료
            if (linkIdToMapId.size() == targetLinkIds.size()) {
                queue.clear();
                break;
            }
        }
    }

    // ─────────────────────────────────────────────────────────────
    // (5) 결과 구성: 입력 순서 보존, 못 찾은 링크는 0
    // ─────────────────────────────────────────────────────────────
    Map<Integer, Integer> result = new LinkedHashMap<>();
    for (Integer linkId : linkIds) {
        result.put(linkId, linkIdToMapId.getOrDefault(linkId, 0));
    }
    return result;
}

// ─────────────────────────────────────────────────────────────────────
// 보조 클래스 / 유틸리티
// ─────────────────────────────────────────────────────────────────────

/** BFS 큐에 들어가는 노드 위치 */
private static class NodePos {
    final Integer nodeId;
    final Integer nodeMapId;
    NodePos(Integer nodeId, Integer nodeMapId) {
        this.nodeId = nodeId;
        this.nodeMapId = nodeMapId;
    }
}

/** 노드 위치 키 생성 (nodeId + mapId 조합) */
private static String nodeKey(Integer nodeId, Integer nodeMapId) {
    return nodeId + "|" + nodeMapId;
}
