// 노드 위치 → 노드 정보 (인접 노드 리스트 통합)
Map<String, NodeVo> nodeIndex = new HashMap<>();

for (NodeVo row : allNodes) {
    String key = nodeKey(row.getNodeId(), row.getNodeMapId());
    NodeVo existing = nodeIndex.get(key);
    
    if (existing == null) {
        // 첫 등장: 그대로 등록
        if (row.getAdjNodeId() != null) {
            NodeVo.AdjNode adj = new NodeVo.AdjNode();
            adj.setAdjNodeId(row.getAdjNodeId());
            adj.setAdjNodeMapId(row.getAdjNodeMapId());
            row.getAdjNodes().add(adj);
        }
        nodeIndex.put(key, row);
    } else if (row.getAdjNodeId() != null) {
        // 이미 등록된 노드: 인접 노드만 추가
        NodeVo.AdjNode adj = new NodeVo.AdjNode();
        adj.setAdjNodeId(row.getAdjNodeId());
        adj.setAdjNodeMapId(row.getAdjNodeMapId());
        existing.getAdjNodes().add(adj);
    }
}

