        && !oppNode.getAdjNodes().isEmpty()) {
    
    // 도엽 경계 노드 → 모든 인접 도엽 짝 노드를 큐에 투입
    for (NodeVo.AdjNode adj : oppNode.getAdjNodes()) {
        String adjKey = nodeKey(adj.getAdjNodeId(), adj.getAdjNodeMapId());
        if (visitedNodes.add(adjKey)) {
            queue.offer(new NodePos(adj.getAdjNodeId(), adj.getAdjNodeMapId()));
        }
    }
} else {
    // 일반 노드 → 그대로 진행
    String nextKey = nodeKey(oppositeNodeId, linkMapId);
    if (visitedNodes.add(nextKey)) {
        queue.offer(new NodePos(oppositeNodeId, linkMapId));
    }
}
